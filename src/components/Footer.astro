---
const socials = [
  { label: "LinkedIn", href: "https://www.linkedin.com/in/seoexpertshishir/" },
  { label: "Instagram", href: "https://www.instagram.com/seoexpertshishir/" },
  { label: "Facebook", href: "https://www.facebook.com/seoexpertshishir2025" },
  { label: "X (twitter)", href: "https://x.com/seoexpershishir" },
];

const explore = [
  { label: "About", href: "/about" },
  { label: "Work", href: "/work" },
  { label: "Contact", href: "/contact" },
];

const year = new Date().getFullYear();
---

<footer class="bg-(--color-footer-bg) text-(--color-footer-text)">
  <div class="max-w-[1280px] mx-auto px-6 md:px-12 py-16 md:py-24">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-8">
      <div>
        <p class="font-display font-bold text-xl tracking-tight">SHISHIR AHMED</p>
      </div>

      <div>
        <p class="text-sm font-semibold mb-4 opacity-60">Explore</p>
        <ul class="space-y-3">
          {explore.map((item) => (
            <li>
              <a href={item.href} class="hover:opacity-70 transition-opacity">{item.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <p class="text-sm font-semibold mb-4 opacity-60">Find me online</p>
        <ul class="space-y-3">
          {socials.map((item) => (
            <li>
              <a href={item.href} target="_blank" rel="noopener noreferrer" class="hover:opacity-70 transition-opacity">{item.label}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-16 md:mt-24 pt-8 border-t border-white/10">
      <p class="text-sm opacity-60">© {year} Shishir Ahmed. All rights reserved.</p>
    </div>
  </div>
</footer>
