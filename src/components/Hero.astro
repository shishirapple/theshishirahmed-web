---
---

<section class="max-w-[1280px] mx-auto px-6 md:px-12 pt-16 md:pt-24 pb-16 md:pb-24" id="hero">
  <h1 class="font-display font-bold leading-[0.95] tracking-tight flex flex-wrap items-center gap-x-3 gap-y-2">
    <span class="text-[15vw] md:text-[7vw] lg:text-[88px]">SHISHIR AHMED</span>
    <span class="hidden md:inline-block text-(--color-border) text-[7vw] lg:text-[88px] mx-1">|</span>

    <span class="inline-flex flex-col leading-tight">
      <span id="hero-designer" class="hero-reveal-text font-display font-bold text-2xl md:text-3xl">
        Designer.
      </span>
      <span id="hero-strategist" class="hero-reveal-text font-display text-2xl md:text-3xl text-(--color-muted)">
        Strategist
      </span>
    </span>
  </h1>

  <p class="mt-4 font-display text-2xl md:text-3xl text-(--color-muted)">with a marketing mind</p>
</section>

<script>
  function setupHeroAnimation() {
    const hero = document.getElementById("hero");
    const designer = document.getElementById("hero-designer");
    const strategist = document.getElementById("hero-strategist");

    if (!hero || !designer || !strategist) return;

    const playAnimation = () => {
      designer.classList.remove("in-view");
      strategist.classList.remove("in-view");
      void (designer as HTMLElement).offsetWidth;

      requestAnimationFrame(() => {
        designer.classList.add("in-view");
        setTimeout(() => strategist.classList.add("in-view"), 120);
      });
    };

    const resetAnimation = () => {
      designer.classList.remove("in-view");
      strategist.classList.remove("in-view");
    };

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            playAnimation();
          } else {
            resetAnimation();
          }
        });
      },
      { threshold: 0.4 }
    );

    observer.observe(hero);
  }

  setupHeroAnimation();
  document.addEventListener("astro:after-swap", setupHeroAnimation);
</script>
