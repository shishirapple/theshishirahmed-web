---
---

<section class="max-w-[1280px] mx-auto px-6 md:px-12 pt-16 md:pt-24 pb-16 md:pb-24" id="hero">
  <h1 class="font-display font-bold leading-[0.95] tracking-tight">
    <span class="block text-[15vw] md:text-[7vw] lg:text-[88px]">
      SHISHIR AHMED
      <span class="inline-block align-middle mx-2 text-(--color-border)">|</span>
    </span>
  </h1>

  <div class="mt-4 md:mt-2 flex flex-wrap items-baseline gap-x-3">
    <svg
      id="hero-designer-svg"
      width="220"
      height="48"
      viewBox="0 0 220 48"
      class="h-9 md:h-10 w-auto overflow-visible"
      aria-hidden="true"
    >
      <text
        id="hero-designer-path"
        x="0"
        y="36"
        class="hero-draw-path"
        font-family="Space Grotesk, sans-serif"
        font-size="36"
        font-weight="700"
      >Designer.</text>
    </svg>
    <span class="sr-only">Designer.</span>

    <span class="overflow-hidden inline-block align-bottom">
      <span id="hero-strategist" class="hero-slide-word font-display text-2xl md:text-3xl text-(--color-muted)">
        Strategist
      </span>
    </span>
  </div>
  <p class="mt-1 font-display text-2xl md:text-3xl text-(--color-muted)">with a marketing mind</p>
</section>

<script>
  function setupHeroAnimation() {
    const hero = document.getElementById("hero");
    const designerPath = document.getElementById("hero-designer-path");
    const strategistWord = document.getElementById("hero-strategist");

    if (!hero || !designerPath || !strategistWord) return;

    const measure = () => {
      const length = (designerPath as unknown as SVGTextElement).getComputedTextLength?.() || 200;
      designerPath.setAttribute(
        "style",
        `stroke-dasharray:${length}; stroke-dashoffset:${length};`
      );
    };
    measure();
    window.addEventListener("resize", measure);

    const playAnimation = () => {
      // Reset first so it can replay
      designerPath.classList.remove("in-view");
      strategistWord.classList.remove("in-view");
      // Force reflow to restart CSS transition
      void (designerPath as unknown as HTMLElement).offsetWidth;

      requestAnimationFrame(() => {
        designerPath.classList.add("in-view");
        strategistWord.classList.add("in-view");
      });
    };

    const resetAnimation = () => {
      designerPath.classList.remove("in-view");
      strategistWord.classList.remove("in-view");
    };

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            playAnimation();
          } else {
            resetAnimation();
          }
        });
      },
      { threshold: 0.4 }
    );

    observer.observe(hero);
  }

  setupHeroAnimation();
  document.addEventListener("astro:after-swap", setupHeroAnimation);
</script>
