---
export interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const links = [
  { href: "/", label: "Home" },
  { href: "/work", label: "Work" },
  { href: "/about", label: "About" },
];

function isActive(href: string) {
  return currentPath === href;
}
---

<header class="sticky top-0 z-50 bg-(--color-bg)/90 backdrop-blur-sm border-b border-(--color-border)">
  <nav
    class="max-w-[1280px] mx-auto flex items-center justify-between px-6 md:px-12 py-4 md:py-6"
    aria-label="Primary"
  >
    <div class="flex items-center gap-2">
      {links.map((link) => (
        <a
          href={link.href}
          class:list={[
            "nav-link chip",
            isActive(link.href) ? "chip-dark" : "",
          ]}
          aria-current={isActive(link.href) ? "page" : undefined}
        >
          <span>{link.label}</span>
          <svg class="nav-arrow" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <path d="M3 9L9 3M9 3H4M9 3V8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      ))}
    </div>

    <div class="flex items-center gap-3">
      <button
        id="theme-toggle"
        type="button"
        class="chip"
        aria-label="Toggle dark mode"
      >
        <svg id="icon-sun" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <circle cx="8" cy="8" r="3.5" stroke="currentColor" stroke-width="1.3"/>
          <path d="M8 1V2.5M8 13.5V15M15 8H13.5M2.5 8H1M12.7 3.3L11.6 4.4M4.4 11.6L3.3 12.7M12.7 12.7L11.6 11.6M4.4 4.4L3.3 3.3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
        </svg>
        <svg id="icon-moon" width="16" height="16" viewBox="0 0 16 16" fill="none" class="hidden" aria-hidden="true">
          <path d="M14 9.3A6 6 0 116.7 2 4.7 4.7 0 0014 9.3z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/>
        </svg>
      </button>

      <a href="/contact" class="nav-link chip chip-dark">
        <span>Start Project</span>
        <svg class="nav-arrow" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <path d="M3 9L9 3M9 3H4M9 3V8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </nav>
</header>

<script>
  function setIcon() {
    const isDark = document.documentElement.classList.contains("dark");
    document.getElementById("icon-sun")?.classList.toggle("hidden", isDark);
    document.getElementById("icon-moon")?.classList.toggle("hidden", !isDark);
  }
  setIcon();

  document.getElementById("theme-toggle")?.addEventListener("click", () => {
    document.documentElement.classList.toggle("dark");
    const isDark = document.documentElement.classList.contains("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
    setIcon();
  });
</script>
