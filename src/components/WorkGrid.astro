---
import { Image } from "astro:assets";
import type { Project } from "../data/projects";

export interface Props {
  projects: Project[];
  stagger?: boolean;
}

const { projects, stagger = false } = Astro.props;

// Resolve image imports dynamically
const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/projects/*.{png,jpg,jpeg}",
  { eager: true }
);

function getImage(filename: string) {
  const match = Object.entries(images).find(([path]) => path.endsWith(filename));
  return match?.[1]?.default;
}
---

<div class:list={["work-grid grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12", stagger ? "stagger" : ""]}>
  {projects.map((project, index) => {
    const img = getImage(project.image);
    return (
      <article class="work-card group opacity-0" data-work-index={index}>
        <a href={`/work/${project.slug}`} class="block">
          <div class="relative overflow-hidden rounded-xl bg-(--color-surface) border border-(--color-border) aspect-[4/3]">
            {img && (
              <Image
                src={img}
                alt={`Screenshot of ${project.name} website - ${project.tagline}`}
                width={760}
                height={570}
                loading={index < 2 ? "eager" : "lazy"}
                fetchpriority={index < 2 ? "high" : "auto"}
                format="webp"
                quality={75}
                class="w-full h-full object-cover object-top transition-transform duration-500 group-hover:scale-[1.03]"
              />
            )}
          </div>
          <h3 class="mt-4 font-display font-bold text-lg tracking-tight">{project.name}</h3>
          <p class="mt-1 text-sm text-(--color-muted)">{project.tagline}</p>
        </a>
      </article>
    );
  })}
</div>

<script>
  import gsap from "gsap";
  import ScrollTrigger from "gsap/ScrollTrigger";
  
  gsap.registerPlugin(ScrollTrigger);

  function setupWorkGridAnimation() {
    const workCards = document.querySelectorAll(".work-card");
    
    if (workCards.length === 0) return;

    // Kill any existing animations
    gsap.killTweensOf(workCards);
    
    // Reset state
    gsap.set(workCards, { opacity: 0, y: 40 });

    // Create staggered animation with ScrollTrigger
    gsap.to(workCards, {
      opacity: 1,
      y: 0,
      duration: 0.6,
      ease: "power3.out",
      stagger: 0.1,
      scrollTrigger: {
        trigger: ".work-grid",
        start: "top 80%",
        toggleActions: "play none none reverse",
      },
    });
  }

  setupWorkGridAnimation();
  document.addEventListener("astro:after-swap", setupWorkGridAnimation);
</script>
