---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import profilePhoto from "../assets/profile/shishir.jpg";

const clients = [
  "Curry Mile",
  "Vinifinds",
  "Lice Expert Salon",
  "Momena Autos",
  "SinovaAdvisory",
];

const manifesto = [
  "Win client's hearts",
  "Do the hard work",
  "Be better together",
  "Enjoy the ride",
  "Play big",
];
---

<Layout
  title="About — Shishir Ahmed"
  description="WordPress Developer & Digital Marketer based in Rajshahi, Bangladesh. Crafting high-performance custom WordPress websites and full-funnel digital marketing strategies."
>
  <Navbar currentPath="/about" />

  <main>
    <section class="max-w-[1280px] mx-auto px-6 md:px-12 pt-16 md:pt-24 pb-24 md:pb-32">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 md:gap-24">
        <!-- Left column -->
        <div>
          <h1 class="font-display font-bold text-4xl md:text-5xl tracking-tight">Nice to meet you!</h1>

          <p class="mt-6 text-(--color-muted) max-w-md leading-relaxed">
            WordPress Developer & Digital Marketer. Crafting high-performance custom
            WordPress websites and implementing full-funnel digital marketing strategies.
            Based in Rajshahi, Bangladesh.
          </p>

          <div class="mt-8 flex flex-wrap gap-3">
            <span class="chip">Learning about WordPress performance</span>
            <span class="chip">Listening to lo-fi focus mixes</span>
            <span class="chip">Enjoying client wins</span>
          </div>

          <div class="mt-16">
            <h2 class="text-sm font-semibold uppercase tracking-wide text-(--color-muted)">Clients</h2>
            <ul class="mt-4 space-y-2">
              {clients.map((client) => (
                <li class="font-display text-lg">{client}</li>
              ))}
            </ul>
          </div>

          <div class="mt-16">
            <h2 class="text-sm font-semibold uppercase tracking-wide text-(--color-muted)">Industries Served</h2>
            <p class="mt-4 text-(--color-muted) max-w-md leading-relaxed">
              Healthcare, Food &amp; Beverage, Real Estate, Automotive, Technology,
              Construction &amp; Development, Travel, Commerce, Professional Services.
            </p>
          </div>
        </div>

        <!-- Right column -->
        <div>
          <div class="flex items-center gap-2 text-sm font-medium">
            <span class="w-2 h-2 rounded-full bg-(--color-status)"></span>
            <span>Available for new projects</span>
          </div>

          <div class="mt-6 rounded-xl overflow-hidden border border-(--color-border) bg-(--color-surface) aspect-[4/5] max-w-sm grayscale">
            <img
              src={profilePhoto.src}
              width={profilePhoto.width}
              height={profilePhoto.height}
              alt="Portrait of Shishir Ahmed"
              class="w-full h-full object-cover object-top"
            />
          </div>

          <div class="mt-12">
            <h2 class="text-sm font-semibold uppercase tracking-wide text-(--color-muted)">Email</h2>
            <a href="mailto:seoexpertshishir.ahmed@gmail.com" class="mt-2 inline-block font-display text-lg hover:opacity-70 transition-opacity">
              seoexpertshishir.ahmed@gmail.com
            </a>
          </div>

          <div class="mt-8">
            <h2 class="text-sm font-semibold uppercase tracking-wide text-(--color-muted)">Resume</h2>
            <a href="/shishir-ahmed-cv.pdf" download class="mt-2 inline-block font-display text-lg hover:opacity-70 transition-opacity">
              /shishir-ahmed-cv.pdf
            </a>
          </div>

          <div class="mt-16">
            <h2 class="text-sm font-semibold uppercase tracking-wide text-(--color-muted)">Manifesto</h2>
            <ol class="mt-4 space-y-2">
              {manifesto.map((item, i) => (
                <li class="font-display text-lg">
                  <span class="text-(--color-muted) mr-2">{String(i + 1).padStart(2, "0")}</span>{item}
                </li>
              ))}
            </ol>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
