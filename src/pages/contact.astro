---

<Layout
  title="Contact — Shishir Ahmed"
  description="Get in touch with Shishir Ahmed for WordPress development and digital marketing projects. Available for new projects."
>
  <Navbar currentPath="/contact" />

  <main>
    <section class="max-w-[1280px] mx-auto px-6 md:px-12 pt-16 md:pt-24 pb-8">
      <div class="flex items-center gap-2 text-sm font-medium">
        <span class="w-2 h-2 rounded-full bg-(--color-status)"></span>
        <span>Available for new projects</span>
      </div>
    </section>

    <section class="max-w-[1280px] mx-auto px-6 md:px-12 pb-24 md:pb-32">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 md:gap-24">
        <!-- Form -->
        <div>
          <h1 class="font-display font-bold text-4xl md:text-5xl tracking-tight">Let's work together</h1>

          <form class="mt-10 space-y-6" id="contact-form">
            <div data-fs-success class="hidden rounded-lg bg-(--color-surface) border border-(--color-border) px-4 py-3 text-sm" role="status"></div>
            <div data-fs-error class="hidden rounded-lg border border-(--color-status)/40 px-4 py-3 text-sm text-(--color-text)" role="alert"></div>

            <div>
              <label for="name" class="block text-sm font-semibold uppercase tracking-wide text-(--color-muted) mb-2">
                Name
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                placeholder="Your name"
                data-fs-field
                class="w-full px-4 py-3 rounded-lg bg-(--color-surface) border border-(--color-border) text-(--color-text) placeholder:text-(--color-muted) focus:outline-none focus-visible:outline-2 focus-visible:outline-(--color-text) focus-visible:outline-offset-2"
              />
              <span data-fs-error="name" class="block mt-1 text-sm text-(--color-muted)"></span>
            </div>

            <div>
              <label for="email" class="block text-sm font-semibold uppercase tracking-wide text-(--color-muted) mb-2">
                Email
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="Your email"
                data-fs-field
                class="w-full px-4 py-3 rounded-lg bg-(--color-surface) border border-(--color-border) text-(--color-text) placeholder:text-(--color-muted) focus:outline-none focus-visible:outline-2 focus-visible:outline-(--color-text) focus-visible:outline-offset-2"
              />
              <span data-fs-error="email" class="block mt-1 text-sm text-(--color-muted)"></span>
            </div>

            <div>
              <label for="message" class="block text-sm font-semibold uppercase tracking-wide text-(--color-muted) mb-2">
                Tell me a bit more about your project
              </label>
              <textarea
                id="message"
                name="message"
                required
                rows="5"
                placeholder="The more details the better!"
                data-fs-field
                class="w-full px-4 py-3 rounded-lg bg-(--color-surface) border border-(--color-border) text-(--color-text) placeholder:text-(--color-muted) focus:outline-none focus-visible:outline-2 focus-visible:outline-(--color-text) focus-visible:outline-offset-2 resize-y"
              ></textarea>
              <span data-fs-error="message" class="block mt-1 text-sm text-(--color-muted)"></span>
            </div>

            <button
              type="submit"
              data-fs-submit-btn
              class="w-full md:w-auto px-8 py-3 rounded-lg bg-(--color-text) text-(--color-bg) font-semibold uppercase tracking-wide text-sm hover:opacity-90 transition-opacity disabled:opacity-50 disabled:cursor-not-allowed"
            >
              Submit
            </button>
          </form>
        </div>

        <!-- Direct contact -->
        <div>
          <div>
            <h2 class="text-sm font-semibold uppercase tracking-wide text-(--color-muted)">Email</h2>
            <a href="mailto:seoexpertshishir.ahmed@gmail.com" class="mt-2 inline-block font-display text-lg hover:opacity-70 transition-opacity">
              seoexpertshishir.ahmed@gmail.com
            </a>
          </div>

          <div class="mt-10">
            <h2 class="text-sm font-semibold uppercase tracking-wide text-(--color-muted)">WhatsApp</h2>
            <a
              href="https://wa.me/8801723620982"
              target="_blank"
              rel="noopener noreferrer"
              class="mt-2 inline-block font-display text-lg hover:opacity-70 transition-opacity"
            >
              +880 1723-620982
            </a>
          </div>

          <div class="mt-10">
            <h2 class="text-sm font-semibold uppercase tracking-wide text-(--color-muted)">Social Media</h2>
            <div class="mt-4 flex gap-4">
              {socials.map((social) => (
                <a
                  href={social.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={social.label}
                  class="w-10 h-10 rounded-lg bg-(--color-surface) border border-(--color-border) flex items-center justify-center hover:bg-(--color-text) hover:text-(--color-bg) transition-colors"
                >
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d={social.icon} />
                  </svg>
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script src="https://unpkg.com/@formspree/ajax@1" defer></script>
<script>
  function setupFormspree() {
    // @ts-ignore — loaded globally via the CDN script above
    if (typeof window.formspree === "undefined") {
      // Library not loaded yet — retry shortly (defer script may still be parsing)
      setTimeout(setupFormspree, 50);
      return;
    }
    // @ts-ignore
    window.formspree("initForm", {
      formElement: "#contact-form",
      formId: "xwvjdjgn",
    });
  }
  setupFormspree();
</script>
