    icon: "M22 12a10 10 0 10-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.78-3.89 1.1 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.44 2.89h-2.34v6.99A10 10 0 0022 12z",
  },
  {
    label: "X",
    href: "https://x.com/seoexpershishir",
    icon: "M18.9 1.65h3.4l-7.4 8.46 8.71 11.5H17l-5.4-7.06-6.18 7.06H1.99l7.92-9.05L1.5 1.65h7.16l4.88 6.45 5.36-6.45zM17.7 19.5h1.88L7.1 3.55H5.08L17.7 19.5z",
  },
