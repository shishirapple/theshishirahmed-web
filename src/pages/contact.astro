---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

const socials = [
  {
    label: "LinkedIn",
    href: "https://www.linkedin.com/in/seoexpertshishir/",
    icon: "M4.98 3.5C4.98 4.88 3.88 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1 4.98 2.12 4.98 3.5zM.5 8h4V23h-4V8zM8.5 8h3.8v2.05h.05c.53-1 1.83-2.05 3.77-2.05 4.03 0 4.78 2.65 4.78 6.1V23h-4v-6.9c0-1.65-.03-3.77-2.3-3.77-2.3 0-2.65 1.8-2.65 3.65V23h-4V8z",
  },
  {
    label: "Instagram",
    href: "https://www.instagram.com/seoexpertshishir/",
    icon: "M12 2.2c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.7 3.7 0 01-1.38-.9 3.7 3.7 0 01-.9-1.38c-.16-.42-.36-1.06-.41-2.23C2.21 15.58 2.2 15.2 2.2 12s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.42 2.21 8.8 2.2 12 2.2zm0-2.2C8.74 0 8.33.01 7.05.07c-1.28.06-2.15.26-2.91.56a5.9 5.9 0 00-2.14 1.4A5.9 5.9 0 00.6 4.17c-.3.76-.5 1.63-.56 2.91C0 8.36 0 8.77 0 12s.01 3.64.07 4.92c.06 1.28.26 2.15.56 2.91.3.78.7 1.45 1.4 2.14.7.7 1.36 1.1 2.14 1.4.76.3 1.63.5 2.91.56C8.36 24 8.77 24 12 24s3.64-.01 4.92-.07c1.28-.06 2.15-.26 2.91-.56a5.9 5.9 0 002.14-1.4 5.9 5.9 0 001.4-2.14c.3-.76.5-1.63.56-2.91.06-1.28.07-1.69.07-4.92s-.01-3.64-.07-4.92c-.06-1.28-.26-2.15-.56-2.91a5.9 5.9 0 00-1.4-2.14A5.9 5.9 0 0019.83.63c-.76-.3-1.63-.5-2.91-.56C15.64.01 15.23 0 12 0z M12 5.84A6.16 6.16 0 1012 18.16 6.16 6.16 0 0012 5.84zm0 10.16A4 4 0 1112 8a4 4 0 010 8zM18.4 5.6a1.44 1.44 0 11-2.88 0 1.44 1.44 0 012.88 0z",
  },
  {
    label: "Facebook",
